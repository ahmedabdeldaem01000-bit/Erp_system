{
  "info": {
    "name": "Herd ERP Accounting API",
    "description": "Postman collection for Accounts, Journal Entries, and Reverse Entry APIs.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "version": "1.0.0"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8000/api",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "YOUR_TOKEN_HERE",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Accounts",
      "item": [
        {
          "name": "List Accounts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/accounts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "accounts"
              ]
            }
          }
        },
        {
          "name": "Get Account",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/accounts/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "accounts",
                ":id"
              ]
            }
          }
        },
        {
          "name": "Create Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"1000\",\n  \"name\": \"Cash\",\n  \"type\": \"asset\",\n  \"parent_id\": null,\n  \"is_postable\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/accounts",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "accounts"
              ]
            }
          }
        },
        {
          "name": "Update Account",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"1000\",\n  \"name\": \"Cash on Hand\",\n  \"type\": \"asset\",\n  \"parent_id\": null,\n  \"is_postable\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/accounts/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "accounts",
                ":id"
              ]
            }
          }
        },
        {
          "name": "Archive Account",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/accounts/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "accounts",
                ":id"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Journal Entries",
      "item": [
        {
          "name": "List Journal Entries",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/journal-entries",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "journal-entries"
              ]
            }
          }
        },
        {
          "name": "Get Journal Entry",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/journal-entries/:id",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "journal-entries",
                ":id"
              ]
            }
          }
        },
        {
          "name": "Create Journal Entry",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"entry_date\": \"2026-06-14\",\n  \"description\": \"Sales receipt\",\n  \"lines\": [\n    {\n      \"account_id\": 1,\n      \"debit\": 1000.00,\n      \"credit\": 0.00,\n      \"description\": \"Cash received\"\n    },\n    {\n      \"account_id\": 2,\n      \"debit\": 0.00,\n      \"credit\": 1000.00,\n      \"description\": \"Service revenue\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/journal-entries",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "journal-entries"
              ]
            }
          }
        },
        {
          "name": "Reverse Journal Entry",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/journal-entries/:id/reverse",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "journal-entries",
                ":id",
                "reverse"
              ]
            }
          }
        }
      ]
    }
  ]
}
